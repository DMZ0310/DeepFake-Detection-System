# DeepFake Detection System Environment Variables

# Model Configuration
MODEL_PATH=weights/deepfake_model.h5
CONFIDENCE_THRESHOLD=0.5
SEQUENCE_LENGTH=20
FRAME_SIZE=224
BATCH_SIZE=16

# Paths
DATASET_PATH=dataset/
OUTPUT_PATH=outputs/
REPORTS_PATH=reports/
LOGS_PATH=logs/

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# App Settings
MAX_UPLOAD_SIZE_MB=500
SUPPORTED_FORMATS=mp4,avi,mov,mkv

# Training
EPOCHS=50
LEARNING_RATE=0.0001
TRAIN_SPLIT=0.8
VAL_SPLIT=0.1
TEST_SPLIT=0.1
